# =================================================================
# VoxReach AI - Environment Configuration Template
# =================================================================
# Instructions:
# 1. Copy this file to a new file named '.env'
# 2. Update the values below with your actual API keys and settings.
# 3. Do NOT commit your '.env' file to version control.
# =================================================================

# --- Application Settings ---
APP_NAME="VoxReach AI"
DEBUG=True

# --- AI Configuration ---
# Options: 'openai', 'openrouter', etc.
AI_PROVIDER=openrouter

# Get your key at: https://openrouter.ai/keys
AI_API_KEY=your_openrouter_key_here

# Base URL for the AI API (Default is OpenRouter)
AI_BASE_URL=https://openrouter.ai/api/v1

# Recommended Model: google/gemini-2.0-flash-lite-preview-02-05:free
AI_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free

# --- Storage Settings ---
# Directory where CSV uploads and processed files are stored
UPLOAD_DIR="uploads"

# --- Optional Integrations ---
# Options: 'twilio', 'pywhatkit'
NOTIFICATION_PROVIDER="twilio"

# ElevenLabs (Voice Synthesis) - Get key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=""

# Twilio (SMS/Voice/WhatsApp Outreach) - Get keys at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER=""
